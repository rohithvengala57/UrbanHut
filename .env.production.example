# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL with PostGIS. Use RDS in production.
DATABASE_URL=postgresql+asyncpg://urbanhut:<password>@<rds-host>:5432/urbanhut

# ─── Redis ────────────────────────────────────────────────────────────────────
# ElastiCache Redis in production.
REDIS_URL=redis://<elasticache-host>:6379/0

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=<generate-strong-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AWS ──────────────────────────────────────────────────────────────────────
# IAM user or role with s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket.
AWS_S3_BUCKET=urbanhut-uploads-prod
AWS_ACCESS_KEY_ID=<iam-access-key-id>
AWS_SECRET_ACCESS_KEY=<iam-secret-access-key>
AWS_REGION=us-east-1

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=<resend-api-key>

# ─── Geocoding ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=<google-maps-api-key>

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-client-id>
APPLE_SIGN_IN_KEY=<apple-sign-in-key>
