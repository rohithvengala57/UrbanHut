# Database
DATABASE_URL=postgresql+asyncpg://urbanhut:urbanhut_dev@localhost:5432/urbanhut

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# AWS S3 (for verification documents and listing images)
# Leave blank to disable image upload gracefully
AWS_S3_BUCKET=urbanhut-uploads
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Expo push notifications (optional — skipped if not set)
EXPO_ACCESS_TOKEN=

# Email (Resend.com)
RESEND_API_KEY=your-resend-api-key

# Google
GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
